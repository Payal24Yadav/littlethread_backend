# Backend environment variables (example)
# Use this as a template. Do NOT commit real secrets.

# Server
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# Database (MySQL)
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/littlethreads

# Auth (required)
JWT_SECRET=change_me_to_a_long_random_string

# Email (OTP + invoices) (required for current backend startup)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# Shiprocket (shipping + webhooks)
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_POSTCODE=110001
SHIPROCKET_API_KEY=change_me  # used as X-API-Key for webhook endpoint protection

# Optional Shiprocket knobs
SHIPROCKET_TOKEN=
SHIPROCKET_STRICT_TOKEN=false
SHIPROCKET_REQUEST_TIMEOUT_MS=8000
SHIPROCKET_SERVICEABILITY_TIMEOUT_MS=3000
SHIPROCKET_RETRY_WORKER_INTERVAL_MS=60000
SHIPROCKET_RETRY_WORKER_BATCH_SIZE=10
SHIPROCKET_RETRY_WORKER_MAX_ATTEMPTS=6
SHIPROCKET_ENABLE_RETRY_WORKER=true
SHIPROCKET_ENABLE_AUTO_SHIPPING=false
SHIPROCKET_AUTO_CREATE_SHIPMENT=false
SHIPROCKET_AUTO_SCHEDULE_PICKUP=false
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_FALLBACK_EMAIL=
SHIPMENT_CREATE_MAX_ATTEMPTS=3
SHIPMENT_PICKUP_MAX_ATTEMPTS=3

# SMS (OTP + order status notifications)
FAST2SMS_API_KEY=

# Google login (customer)
GOOGLE_CLIENT_ID=

