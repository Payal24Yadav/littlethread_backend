generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id                String           @id @default(uuid())
  name              String
  subtitle          String?
  handle            String           @unique
  description       String?          @db.Text
  productType       String?
  gender            String?
  ageGroup          String?
  season            String?
  price             Float
  compareAtPrice    Float?
  costPrice         Float?
  isDiscountable    Boolean          @default(false)
  discountPrice     Float?
  images            Json
  thumbnailUrl      String?
  hoverThumbnailUrl String?
  stock             Int              @default(0)
  weight            Float?
  length            Float?
  breadth           Float?
  height            Float?
  active            Boolean          @default(true)
  tags              Json?
  brandId           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orderItems        OrderItem[]
  variants          ProductVariant[]
  reviews           Review[]
  sales             Sale[]
  brand             Brand?           @relation(fields: [brandId], references: [id])
  categories        Category[]       @relation("CategoryToProduct")
  collections       Collection[]     @relation("CollectionToProduct")

  @@index([price])
  @@index([name])
  @@index([createdAt])
  @@index([stock])
  @@index([active])
  @@index([handle])
  @@index([brandId])
  @@index([productType])
  @@index([gender])
  @@index([ageGroup])
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())

  products  Product[]
}

model ProductVariant {
  id                String   @id @default(uuid())
  sku               String?
  title             String
  color             String?
  size              String?
  price             Float?
  compareAtPrice    Float?
  costPrice         Float?
  stock             Int      @default(0)
  reservedStock     Int      @default(0)
  barcode           String?
  images            Json
  thumbnailUrl      String?
  hoverThumbnailUrl String?
  weight            Float?
  length            Float?
  breadth           Float?
  height            Float?
  active            Boolean  @default(true)
  productId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@index([sku])
  @@index([active])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userName  String
  userEmail String?
  userPhone String?
  images    Json
  productId String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([rating])
  @@index([createdAt])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())

  products Product[] @relation("CategoryToProduct")
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  imageUrl    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  products Product[] @relation("CollectionToProduct")

  @@index([name])
  @@index([createdAt])
  @@index([order])
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  altText   String?
  linkUrl   String?
  type      String   @default("DESKTOP")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model Order {
  id                 String           @id @default(uuid())
  totalAmount        Float
  status             String           @default("ORDERED")
  paymentStatus      String?          @default("UNPAID")
  codCharges         Float?
  customerId         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  razorpayOrderId    String?          @unique
  razorpayPaymentId  String?          @unique
  razorpaySignature  String?
  paymentMethod      String?
  invoiceNumber      String?          @unique
  shippingAddress    Json?
  deliveryDate       DateTime?
  cancellationReason String?

  customer       Customer?       @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  activities     OrderActivity[]
  returnRequests ReturnRequest[]
  sales          Sale[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([razorpayOrderId])
}

model OrderItem {
  id           String  @id @default(uuid())
  quantity     Int
  price        Float
  productId    String
  productName  String?
  variantTitle String?
  orderId      String

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model OrderActivity {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  message   String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Customer {
  id         String    @id @default(uuid())
  email      String?   @unique
  mobile     String?   @unique
  name       String?
  gender     String?
  password   String?
  provider   String    @default("local")
  otp        String?
  otpExpires DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  addresses Address[]
  orders    Order[]

  @@index([email])
  @@index([mobile])
  @@index([createdAt])
}

model MobileOtp {
  id         String   @id @default(uuid())
  mobile     String   @unique
  otpHash    String
  expiresAt  DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

model Address {
  id           String   @id @default(uuid())
  customerId   String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([pincode])
}

model Profile {
  id        String   @id
  email     String   @unique
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  is2FAEnabled Boolean  @default(false)
  otp          String?
  otpExpires   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Sale {
  id            String   @id @default(uuid())
  productId     String
  quantity      Int
  price         Float
  source        String   @default("Website")
  customerName  String?
  customerEmail String?
  customerPhone String?
  paymentMode   String?
  paymentId     String?
  notes         String?
  variantTitle  String?
  createdAt     DateTime @default(now())
  orderId       String?

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GlobalSetting {
  id         String   @id @default("default")
  codEnabled Boolean  @default(false)
  codMaxAmount Float?
  codCharges   Float?  @default(0)
  updatedAt  DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  percentage    Float
  type          String   @default("PERCENTAGE")
  isActive      Boolean  @default(true)
  maxUses       Int?
  usedCount     Int      @default(0)
  allowedEmails Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model Shipment {
  id         String   @id @default(uuid())
  orderId    String   @unique
  awb        String   @unique
  shipmentId String   @unique
  pickupId   String?
  courier    String
  status     String   @default("SHIPMENT_CREATED")
  labelUrl   String?
  lastTrackedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId])
  @@index([awb])
  @@index([status])
}

model WebhookLog {
  id              String   @id @default(uuid())
  provider        String   @default("SHIPROCKET")
  eventType       String   @default("STATUS_UPDATE")
  orderId         String?
  awb             String?
  shipmentId      String?
  headers         Json?
  payload         Json
  receivedAt      DateTime @default(now())
  processed       Boolean  @default(false)
  processedAt     DateTime?
  processingError String?
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?

  @@index([provider])
  @@index([orderId])
  @@index([awb])
  @@index([processed])
  @@index([receivedAt])
}

model ShipmentTrackingEvent {
  id         String   @id @default(uuid())
  provider   String   @default("SHIPROCKET")
  source     String   @default("WEBHOOK") // WEBHOOK | POLL
  orderId    String?
  awb        String?
  shipmentId String?
  status     String
  eventTime  DateTime @default(now())
  raw        Json?
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([awb])
  @@index([shipmentId])
  @@index([eventTime])
}

model FailedShipment {
  id            String   @id @default(uuid())
  provider      String   @default("SHIPROCKET")
  orderId       String
  stage         String   // CREATE_SHIPMENT | ASSIGN_AWB | SCHEDULE_PICKUP | TRACK_SYNC
  payload       Json?
  errorMessage  String
  errorDetails  Json?
  attempts      Int      @default(0)
  lastAttemptAt DateTime?
  resolved      Boolean  @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([stage])
  @@index([resolved])
  @@index([createdAt])
}

model ReturnRequest {
  id                     String   @id @default(uuid())
  orderId                String
  reason                 String
  description            String?
  type                   String   @default("RETURN")
  preferredVariantTitle  String?
  returnDate             DateTime @default(now())
  status                 String   @default("PENDING")
  pickupStatus           String   @default("REQUESTED")
  inspectionStatus       String   @default("PENDING")
  adminResponse          String?
  refundAmount           Float?
  refundStatus           String   @default("PENDING")
  refundCompletedAt      DateTime?
  returnShipmentId       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([refundStatus])
}
