
## Shiprocket (example)
# Required for API calls (recommended: use email+password OR SHIPROCKET_TOKEN)
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=your_password_here
# Optional: provide a valid JWT token instead of email/password
# SHIPROCKET_TOKEN=eyJhbGciOi...

# Shiprocket API base URL (default is https://apiv2.shiprocket.in)
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in

# Pickup configuration
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_POSTCODE=560001

# Webhook security (required in production)
SHIPROCKET_API_KEY=replace_with_strong_random_secret
SHIPROCKET_STRICT_TOKEN=true

# Shipping automation flags
# Auto-create shipment after payment verification / COD confirmation
SHIPROCKET_AUTO_CREATE_SHIPMENT=true
# Auto-schedule pickup after AWB assignment
SHIPROCKET_AUTO_SCHEDULE_PICKUP=true

# Retry/tuning
SHIPMENT_CREATE_MAX_ATTEMPTS=3

SHIPMENT_PICKUP_MAX_ATTEMPTS=3
SHIPROCKET_REQUEST_TIMEOUT_MS=8000
SHIPROCKET_SERVICEABILITY_TIMEOUT_MS=3000
